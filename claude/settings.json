{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(just:*)",
      "Bash(nix:*)",
      "Bash(bat *)",
      "Bash(deadnix *)",
      "Bash(file *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(ls *)",
      "Bash(nixfmt *)",
      "Bash(pre-commit *)",
      "Bash(sed *)",
      "Bash(shellcheck *)",
      "Bash(shuf *)",
      "Bash(statix *)",
      "Bash(stylua *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(zsh *)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:nix-community.github.io)",
      "WebFetch(domain:mynixos.com)"
    ],
    "deny": [
      "Bash(curl *)",
      "Read(./.env)"
    ],
    "defaultMode": "default"
  }
}
